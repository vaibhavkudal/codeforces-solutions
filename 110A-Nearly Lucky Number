int main()
{
    long long n;
    int count=0;
    scanf("%lld",&n);
    while(n>0)
    {
      int no = n%10;
      if( no==4 || no==7)
      {
        count++;
      } 
      n=n/10;
    }
    if(count==4||count==7)
    {
        printf("YES");
    }
    else
    {
        printf("NO");
    }
}

